{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/config.py": {
      "maxDuration": 10
    },
    "api/source.py": {
      "maxDuration": 10
    },
    "api/events.py": {
      "maxDuration": 60
    },
    "api/video.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/config/runtime.json",
      "destination": "/api/config"
    },
    {
      "source": "/events/config",
      "destination": "/api/events"
    },
    {
      "source": "/video/source",
      "destination": "/api/source"
    },
    {
      "source": "/proxy/video",
      "destination": "/api/video"
    }
  ]
}
